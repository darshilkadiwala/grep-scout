{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "watch-all",
      "type": "shell",
      "command": "pnpm run watch",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": ".*(Watching for changes|Watching for file changes|built in).*"
        }
      },
      "presentation": {
        "reveal": "never",
        "panel": "shared"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "options": {
        "shell": {
          "executable": "C:\\Program Files\\Git\\bin\\bash.exe",
          "args": ["-c"]
        }
      }
    }
  ]
}
