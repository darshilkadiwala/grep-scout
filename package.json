{
  "name": "grepscout",
  "displayName": "GrepScout: Advanced File Search",
  "description": "Lightning-fast file name search with granular directory filtering",
  "version": "0.0.2",
  "publisher": "darshil-dev",
  "engines": {
    "vscode": "^1.85.0"
  },
  "author": {
    "name": "Darshil Kadiwala"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/darshilkadiwala/grep-scout.git"
  },
  "homepage": "https://github.com/darshilkadiwala/grep-scout#readme",
  "bugs": {
    "url": "https://github.com/darshilkadiwala/grep-scout/issues"
  },
  "license": "SEE LICENSE IN LICENSE.txt",
  "icon": "media/logo.png",
  "galleryBanner": {
    "color": "#007ACC",
    "theme": "dark"
  },
  "keywords": [
    "search",
    "grep",
    "file search",
    "directory search",
    "dir search",
    "folder search",
    "advanced search",
    "explorer",
    "listing",
    "file listing",
    "directory listing",
    "dir listing",
    "list files",
    "list directory",
    "list dir",
    "list folder",
    "find files",
    "find directory",
    "find dir",
    "find folder",
    "grep files",
    "grep directory",
    "grep dir",
    "grep folder",
    "developer tools",
    "extension"
  ],
  "categories": [
    "Visualization",
    "Other"
  ],
  "qna": "https://github.com/darshilkadiwala/grep-scout/issues",
  "extensionKind": [
    "workspace",
    "ui"
  ],
  "capabilities": {
    "virtualWorkspaces": true,
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "browser": "./dist/extension.browser.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "grepscout-container",
          "title": "GrepScout",
          "icon": "media/search-icon.svg"
        }
      ]
    },
    "views": {
      "grepscout-container": [
        {
          "id": "grepscout.sidebar",
          "type": "webview",
          "name": "Search Files",
          "icon": "media/search-icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "grepscout.open",
        "title": "Open GrepScout",
        "category": "GrepScout"
      },
      {
        "command": "grepscout.refreshCache",
        "title": "Refresh Cache",
        "category": "GrepScout",
        "icon": "$(sync)"
      },
      {
        "command": "grepscout.scmCollapseAll",
        "title": "Collapse All",
        "icon": "$(collapse-all)",
        "category": "Source Control"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "grepscout.scmCollapseAll",
          "group": "navigation@10"
        }
      ],
      "view/title": [
        {
          "command": "grepscout.refreshCache",
          "when": "view == grepscout.sidebar",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "GrepScout",
      "properties": {
        "grepscout.maxResults": {
          "type": "number",
          "default": 500,
          "description": "Maximum search results to display in the sidebar."
        },
        "grepscout.historyLimit": {
          "type": "number",
          "default": 50,
          "description": "The number of past search queries to remember."
        },
        "grepscout.debounceDelay": {
          "type": "number",
          "default": 150,
          "description": "Delay in milliseconds before starting a search after typing stops."
        }
      }
    },
    "keybindings": [
      {
        "command": "grepscout.open",
        "key": "ctrl+alt+f",
        "mac": "cmd+alt+f",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run build",
    "build": "pnpm run build:extension && pnpm run build:webview",
    "build:extension": "node esbuild.js --production",
    "build:webview": "cd src/webview && vite build",
    "watch": "run-p watch:*",
    "watch:extension": "node esbuild.js --watch",
    "watch:webview": "cd src/webview && vite build --watch",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies",
    "release": "commit-and-tag-version",
    "lint": "tsc --noEmit && eslint src --cache --fix --max-warnings=0",
    "format": "prettier --write . --cache --ignore-unknown --list-different",
    "postinstall": "pnpm run format",
    "diff": "git diff --cached > temp.txt"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "@vitejs/plugin-react": "^4.2.0",
    "@vscode/vsce": "^2.22.0",
    "commit-and-tag-version": "^12.7.1",
    "esbuild": "^0.20.0",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-prettier": "^3.1.4",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.32.1",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@vscode/codicons": "^0.0.45",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.2.2"
  },
  "commit-and-tag-version": {
    "scripts": {
      "postchangelog": "pnpm run format"
    }
  }
}
